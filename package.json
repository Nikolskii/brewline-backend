{
  "name": "brewline-backend",
  "version": "0.1.0",
  "description": "Brewline backend — REST API и real-time поток статусов заказов",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck:scripts": "tsc -p scripts/tsconfig.json",
    "gen:spec": "tsx scripts/generate-openapi.ts",
    "check:spec": "npm run gen:spec && git diff --exit-code openapi/openapi.yaml",
    "build:types": "npm run gen:spec && openapi-typescript openapi/openapi.yaml -o packages/api-types/src/generated/openapi.ts && cp openapi/openapi.yaml packages/api-types/openapi.yaml && tsc -p packages/api-types/tsconfig.json",
    "seed": "tsx src/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "license": "MIT",
  "dependencies": {
    "express": "^5.2.1",
    "mongodb": "^7.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@asteasolutions/zod-to-openapi": "^9.1.0",
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.9.4",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10",
    "yaml": "^2.9.0"
  }
}
