# openapi-typescript заявляет peer typescript@^5, а у нас TS 6.
# Реальной несовместимости нет (генератор печатает TS-текст, не зависит от версии
# компилятора). legacy-peer-deps смягчает проверку peer — и для npm ci в Docker тоже.
legacy-peer-deps=true

# Устойчивость к нестабильной сети (ECONNRESET при загрузке тарболов).
# Действует и локально, и внутри docker build.
fetch-retries=10
fetch-retry-mintimeout=5000
fetch-retry-maxtimeout=60000
fetch-timeout=300000
